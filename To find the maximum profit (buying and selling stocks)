#include<iostream>
#include<climits>
using namespace std;
void maxprofit(int prices[],int n){
    int bestbuy[10000];
    bestbuy[0]=INT_MAX;
    //cout<<bestbuy[0]<<" ";
    for(int i=1;i<n;i++){
        bestbuy[i]=min(bestbuy[i-1],prices[i-1]);
    }
    int maxpro=0;
    for(int i=0;i<n;i++){
        
        int currpro=prices[i]-bestbuy[i];
        maxpro=max(maxpro,currpro);
    }
    cout<<maxpro<<endl;
    
    
    
}



int main(){
    int prices[]={7,1,5,3,6,4};
    int n=sizeof(prices)/sizeof(int);
    maxprofit(prices,n);
    return 0;
    
}
